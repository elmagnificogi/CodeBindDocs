{
  "name": "cim",
  "displayName": "CIM — Code Integrated Manual",
  "description": "Sidecar docs bound to source files, shown in a split pane for VS Code and Cursor.",
  "version": "0.1.0",
  "publisher": "cim",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Documentation"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cim.initialize",
        "title": "CIM: Initialize"
      },
      {
        "command": "cim.bindCurrentFile",
        "title": "CIM: Bind Doc to Current File"
      },
      {
        "command": "cim.revealBoundDoc",
        "title": "CIM: Reveal Bound Doc"
      },
      {
        "command": "cim.toggleSplitSync",
        "title": "CIM: Toggle Split Sync"
      },
      {
        "command": "cim.refreshTree",
        "title": "CIM: Refresh Doc Tree",
        "icon": "$(refresh)"
      },
      {
        "command": "cim.openTarget",
        "title": "CIM: Open Bound Source"
      },
      {
        "command": "cim.revealSourceRange",
        "title": "CIM: Reveal Source Range"
      },
      {
        "command": "cim.openDoc",
        "title": "CIM: Open Bound Doc"
      },
      {
        "command": "cim.openDocsIndex",
        "title": "CIM: Open Docs Index",
        "icon": "$(book)"
      },
      {
        "command": "cim.deleteDoc",
        "title": "CIM: Delete Bound Doc",
        "icon": "$(trash)"
      },
      {
        "command": "cim.rebindDoc",
        "title": "CIM: Rebind Doc to Source"
      },
      {
        "command": "cim.retightenRange",
        "title": "CIM: Retighten Range by Symbol"
      },
      {
        "command": "cim.showDriftIssues",
        "title": "CIM: Show Binding Drift"
      },
      {
        "command": "cim.refreshDocHash",
        "title": "CIM: Refresh Doc contentHash"
      },
      {
        "command": "cim.refreshAllDocHashes",
        "title": "CIM: Mark All Docs Checked (contentHash)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cim",
          "title": "CIM",
          "icon": "media/cim.svg"
        }
      ]
    },
    "views": {
      "cim": [
        {
          "id": "cim.bindings",
          "name": "Bindings"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "cim.openDocsIndex",
          "when": "view == cim.bindings",
          "group": "navigation"
        },
        {
          "command": "cim.refreshTree",
          "when": "view == cim.bindings",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "cim.openTarget",
          "when": "view == cim.bindings && viewItem == binding",
          "group": "inline"
        },
        {
          "command": "cim.openDoc",
          "when": "view == cim.bindings && viewItem == binding",
          "group": "inline"
        },
        {
          "command": "cim.deleteDoc",
          "when": "view == cim.bindings && viewItem == binding",
          "group": "1_modification"
        },
        {
          "command": "cim.rebindDoc",
          "when": "view == cim.bindings && viewItem == binding",
          "group": "1_modification"
        },
        {
          "command": "cim.bindCurrentFile",
          "when": "view == cim.bindings && viewItem == unbound",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "CIM",
      "properties": {
        "cim.docsPath": {
          "type": "string",
          "default": "docs",
          "description": "Workspace-relative folder for CIM Markdown docs (bindings via YAML frontmatter). Default: docs"
        },
        "cim.assetsPath": {
          "type": "string",
          "default": "",
          "description": "Workspace-relative folder for doc assets. Empty = {docsPath}/assets"
        },
        "cim.templatesPath": {
          "type": "string",
          "default": "",
          "description": "Workspace-relative folder for new-doc Markdown templates ({{title}} placeholder). Empty = {docsPath}/_templates. If the folder has .md files they are used; otherwise built-in templates apply."
        },
        "cim.splitSync.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open the bound Markdown doc in a side editor when switching source files."
        },
        "cim.splitSync.promptWhenUnbound": {
          "type": "boolean",
          "default": true,
          "description": "When opening a source file with no CIM binding, show the unbound pane with a create button."
        },
        "cim.splitSync.viewColumn": {
          "type": "string",
          "enum": [
            "Beside",
            "Two"
          ],
          "default": "Beside",
          "description": "Where to open bound docs: Beside the active editor, or always ViewColumn.Two."
        },
        "cim.docPane.mode": {
          "type": "string",
          "enum": [
            "ir",
            "source"
          ],
          "default": "ir",
          "enumDescriptions": [
            "Instant Rendering (Typora-like: type Markdown, render live)",
            "Plain Markdown source (textarea)"
          ],
          "description": "Markdown pane mode. ir = Typora-like instant rendering; source = plain Markdown text."
        },
        "cim.docPane.outline": {
          "type": "boolean",
          "default": true,
          "description": "Show a document outline (TOC) beside the instant-rendering editor."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./ && node scripts/copy-vditor.js",
    "compile:test": "tsc -p tsconfig.test.json",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package --no-dependencies",
    "debug": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/debug.ps1",
    "debug:watch": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/debug.ps1 -Watch",
    "open:vscode": "npm run debug",
    "test:unit": "npm run compile:test && node -r ./test/stubs/register-vscode.js ./out-test/test/runUnit.js",
    "test:integration": "npm run compile && npm run compile:test && node ./out-test/test/runIntegration.js",
    "test": "npm run test:unit && npm run test:integration"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.4.1",
    "glob": "^11.0.1",
    "mocha": "^11.1.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "vditor": "^3.11.2"
  }
}
